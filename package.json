{
  "name": "smartedlabs-admin",
  "description": "SmartEdLabs Admin Dashboard - Data-driven governance for educational institutions, AI operations, and global billing ecosystems.",
  "keywords": [
    "education-admin",
    "ai-governance",
    "nextjs-15",
    "dashboard",
    "tailwindcss",
    "typescript",
    "shadcn"
  ],
  "version": "1.0.0",
  "private": true,
  "author": "SmartEdLabs Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmed-zikrabyte/smartedlab_admin.git"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "biome check --write . && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format . --write",
    "format:check": "biome format . --check",
    "fix-all": "npm run lint:fix && npm run format",
    "type-check": "tsc --noEmit --incremental",
    "upgrade": "npx npm-check-updates -u && npm install",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.508.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@next/eslint-plugin-next": "^15.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lefthook": "^1.12.2",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.2.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "ultracite": "5.0.35"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite format"
    ]
  }
}
